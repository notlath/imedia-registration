{
  "name": "imedia/imedia-registration",
  "description": "IMedia Registration — WordPress form builder and standalone admin app",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "yoast/phpunit-polyfills": "^2.0",
    "wp-phpunit/wp-phpunit": "^7.0",
    "squizlabs/php_codesniffer": "^3.13.0",
    "wp-coding-standards/wpcs": "^3.3.0",
    "phpcsstandards/phpcsutils": "^1.2",
    "phpcsstandards/phpcsextra": "^1.5"
  },
  "autoload-dev": {
    "psr-4": {
      "IMF\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "preflight": "php tests/preflight.php",
    "test": ["@test:unit", "@test:integration"],
    "test:unit": "phpunit --testsuite=unit",
    "test:integration": "phpunit --testsuite=integration",
    "phpcs": "phpcs --standard=phpcs.dist.xml",
    "phpcbf": "phpcbf --standard=phpcs.dist.xml",
    "coverage:html": "phpunit --coverage-html=coverage/html",
    "coverage:clover": "phpunit --coverage-clover=coverage/clover.xml",
    "coverage:report": "phpunit --coverage-text",
    "post-install-cmd": [
      "@php wp-phpunit/wp-phpunit/install-wp-tests.sh"
    ]
  },
  "config": {
    "allow-plugins": false,
    "platform": {
      "php": "8.1"
    }
  }
}
