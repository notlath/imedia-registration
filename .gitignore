# =============================================================================
# IMedia Registration — root .gitignore
# =============================================================================

# ---- Opencode / agent state (per-machine, not source) ----
/.opencode/
/.agents/
/opencode-chat.md
# Note: skills-lock.json IS tracked — it's a lock file like package-lock.json

# ---- IDE / editor / OS clutter ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
*.bak
*.Zone.Identifier

# ---- Composer / PHP dependencies ----
/vendor/

# ---- Node.js (defensive; no JS tooling currently, but referenced in configs) ----
node_modules/

# ---- Test artifacts ----
.phpunit.cache/
coverage/
/wp-registration-plugin/wp-content/plugins/imedia-registration/.phpunit.cache/
/wp-registration-plugin/wp-content/plugins/imedia-registration/coverage/

# ---- Local config (DB credentials, HMAC secret) ----
# config.example.php is committed; real config.php is per-environment.
/config/config.php
/wp-registration-plugin/wp-content/plugins/imedia-registration/config/config.php

# ---- PHP runtime artifacts ----
# Logs (outside of vendor)
/storage/logs/*.log
!/storage/logs/.gitkeep
/wp-registration-plugin/wp-content/plugins/imedia-registration/storage/logs/*.log
!/wp-registration-plugin/wp-content/plugins/imedia-registration/storage/logs/.gitkeep
# Uploads — runtime data, never source
/public/uploads/registrations/*
!/public/uploads/registrations/.gitkeep
/wp-registration-plugin/wp-content/plugins/imedia-registration/public/uploads/registrations/*
!/wp-registration-plugin/wp-content/plugins/imedia-registration/public/uploads/registrations/.gitkeep
# Vendor binaries that may be downloaded later
/vendor/PHPMailer/*.bak
/wp-registration-plugin/wp-content/plugins/imedia-registration/vendor/PHPMailer/*.bak
# Test temp files generated by tests/p?_*.php
/.p5drv_*.php
/tests/.p5drv_*.php
/wp-registration-plugin/wp-content/plugins/imedia-registration/.p5drv_*.php
/wp-registration-plugin/wp-content/plugins/imedia-registration/tests/.p5drv_*.php

# ---- Graphify: cache is derived; tracked files are graph.json, GRAPH_REPORT.md, graph.html ----
/graphify-out/cache/
/wp-registration-plugin/wp-content/plugins/imedia-registration/graphify-out/cache/
