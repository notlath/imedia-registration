# =============================================================================
# IMedia Registration — root .gitignore
# =============================================================================

# ---- Opencode / agent state (per-machine, not source) ----
/.opencode/
/.agents/
/opencode-chat.md
# Note: skills-lock.json IS tracked — it's a lock file like package-lock.json

# ---- IDE / editor / OS clutter ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
*.bak

# ---- Local config (DB credentials, HMAC secret) ----
# config.example.php is committed; real config.php is per-environment.
/config/config.php
/wp-registration-plugin/config/config.php

# ---- PHP runtime artifacts ----
# Logs (outside of vendor)
/storage/logs/*.log
!/storage/logs/.gitkeep
/wp-registration-plugin/storage/logs/*.log
!/wp-registration-plugin/storage/logs/.gitkeep
# Uploads — runtime data, never source
/public/uploads/registrations/*
!/public/uploads/registrations/.gitkeep
/wp-registration-plugin/public/uploads/registrations/*
!/wp-registration-plugin/public/uploads/registrations/.gitkeep
# Vendor binaries that may be downloaded later
/vendor/PHPMailer/*.bak
/wp-registration-plugin/vendor/PHPMailer/*.bak
# Test temp files generated by tests/p?_*.php
/.p5drv_*.php
/tests/.p5drv_*.php
/wp-registration-plugin/.p5drv_*.php
/wp-registration-plugin/tests/.p5drv_*.php

# ---- Optional: ignore graphify-out/cache/ but keep graphify-out/ itself ----
# graphify-out/cache/ contains hundreds of derived files; graph.json,
# GRAPH_REPORT.md, and graph.html are still tracked.
/graphify-out/cache/
/wp-registration-plugin/graphify-out/cache/

